# Football Data Providers
FOOTBALL_DATA_API_KEY=your_football_data_org_key_here

# LLM Provider Chain (at least one required for AI reasoning)
# Primary: Google Gemini
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Secondary: Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Tertiary: OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/goalconsensus?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-this-to-a-random-string-in-production

# Real Settlement — Base Sepolia testnet USDC
# House wallet private key (0x...) — get testnet USDC from https://www.alchemy.com/faucets/base-sepolia
HOUSE_WALLET_PRIVATE_KEY=0x_your_house_wallet_private_key_here
# Optional: override Base Sepolia RPC (default: https://sepolia.base.org)
# BASE_SEPOLIA_RPC=https://sepolia.base.org

# Heuristic fallback is always available (no key required)
